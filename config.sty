\let\oldtitle\title
\let\oldauthor\author
\let\olddate\date 
\renewcommand{\title}[1]{\oldtitle{{\heiti\zihao{1}\bfseries #1}}}
\renewcommand{\author}[1]{\oldauthor{{\heiti\zihao{4}\bfseries #1}}}
\renewcommand{\date}[1]{\olddate{{\heiti\zihao{4}\bfseries #1}}}
\renewcommand{\@maketitle}{%
    \newpage
    \null
    \vskip 2em%
    \begin{center}%
        \let \footnote \thanks
        {\centering\@titlepic\par}%
        \vskip .5em%
        {\LARGE \@title \par}%
        \vskip 1.5em%
        {\large
        \lineskip .5em%
        \begin{tabular}[t]{c}%
            \@author
        \end{tabular}\par}%
        \vskip 1em%
        {\large \@date}%
    \end{center}%
    \par
    \vskip 1.5em}
\makeatother

